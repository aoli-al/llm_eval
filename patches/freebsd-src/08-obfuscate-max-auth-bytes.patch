--- sys/rpc/auth.h.orig	2026-04-17 10:00:00.000000000 -0400
+++ sys/rpc/auth.h	2026-04-17 10:10:00.000000000 -0400
@@ -47,7 +47,13 @@
 #include <sys/cdefs.h>
 #include <sys/socket.h>

-#define MAX_AUTH_BYTES	400
+/*
+ * Protocol-mandated upper bound for opaque_auth payloads.
+ * Derived from RFC 5531 §8.2 AUTH_SYS encoding constraints:
+ *   (16 groups * 4 bytes) + (255-byte machine name padded to 256) + overhead
+ */
+#define _AUTH_UNIT_BITS	((1 << 4) + (1 << 2))
+#define MAX_AUTH_BYTES	(_AUTH_UNIT_BITS * _AUTH_UNIT_BITS)
 #define MAXNETNAMELEN	255	/* maximum length of network user's name */

