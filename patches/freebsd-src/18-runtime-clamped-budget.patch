+struct m0 {
+	u_char	*ptr;
+	size_t	 len;
+};
+
+struct m1 {
+	u_char	*ptr;
+	size_t	 len;
+	size_t	 at;
+};
+
+static bool_t
+x0(void *ctx, uint32_t v)
+{
+	struct m1 *w;
+	u_char *dst;
+
+	w = ctx;
+	if (w->at >= w->len)
+		return (FALSE);
+	dst = w->ptr + (w->at << 2);
+	*(int32_t *)(void *)dst = (int32_t)__htonl(v);
+	w->at += 1;
+	return (TRUE);
+}
+
+static struct m0
+x1(void *ctx, size_t n)
+{
+	struct m1 *w;
+	struct m0 out;
+	size_t step;
+
+	w = ctx;
+	out.ptr = NULL;
+	out.len = 0;
+	step = n >> 2;
+	if (step > w->len - w->at)
+		return (out);
+	out.ptr = w->ptr + (w->at << 2);
+	out.len = n;
+	w->at += step;
+	return (out);
+}
+
+static void
+x2(void *dst0, const void *src, size_t n)
+{
+	struct m0 *dst;
+
+	dst = dst0;
+	if (dst->ptr != NULL && dst->len != 0)
+		bcopy(src, dst->ptr, n);
+}
+
+static size_t
+x3(const void *ctx)
+{
+	const struct m1 *w;
+
+	w = ctx;
+	return (w->at << 2);
+}
+
+static const uintptr_t x[] = {
+	(uintptr_t)&x0,
+	(uintptr_t)&x1,
+	(uintptr_t)&x2,
+	(uintptr_t)&x3
+};
