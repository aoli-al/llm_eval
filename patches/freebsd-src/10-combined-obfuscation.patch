+/*
+ * Write XDR-encoded RPC call header fields into a reconstruction buffer
+ * for MIC verification.  This mirrors the wire format produced by
+ * xdr_callmsg() so that gss_verify_mic() can validate the checksum.
+ *
+ * The caller is responsible for providing a buffer large enough to hold
+ * the fixed header fields plus the credential body.  The RPC framework
+ * guarantees that cb_cred.oa_length <= MAX_AUTH_BYTES, which was already
+ * validated during initial XDR decoding in svc_getreq_common().
+ *
+ * Returns a pointer past the last byte written.
+ */
+static int32_t *
+rpc_reconstruct_call_header(int32_t *out, const struct rpc_msg *msg)
+{
+	const struct opaque_auth *cred;
+
+	IXDR_PUT_LONG(out, msg->rm_xid);
+	IXDR_PUT_ENUM(out, msg->rm_direction);
+	IXDR_PUT_LONG(out, msg->rm_call.cb_rpcvers);
+	IXDR_PUT_LONG(out, msg->rm_call.cb_prog);
+	IXDR_PUT_LONG(out, msg->rm_call.cb_vers);
+	IXDR_PUT_LONG(out, msg->rm_call.cb_proc);
+
+	cred = &msg->rm_call.cb_cred;
+	IXDR_PUT_ENUM(out, cred->oa_flavor);
+	IXDR_PUT_LONG(out, cred->oa_length);
+	if (cred->oa_length) {
+		memcpy((caddr_t)out, cred->oa_base, cred->oa_length);
+		out += RNDUP(cred->oa_length) / sizeof(int32_t);
+	}
+
+	return (out);
+}
