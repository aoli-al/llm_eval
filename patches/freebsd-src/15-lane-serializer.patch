--- sys/rpc/rpcsec_gss/rpcsec_gss_int.h.orig
+++ sys/rpc/rpcsec_gss/rpcsec_gss_int.h
@@ -73,6 +73,81 @@
 /* Maximum sequence number value. */
 #define MAXSEQ		0x80000000
 
+struct rpc_gss_octets {
+	u_char	*base;
+	size_t	 len;
+};
+
+struct rpc_gss_serializer {
+	struct rpc_gss_octets	storage;
+	size_t			lanes_used;
+};
+
+static __inline struct rpc_gss_serializer
+rpc_gss_serializer_new(void *storage, size_t len)
+{
+	struct rpc_gss_serializer serializer;
+
+	serializer.storage.base = storage;
+	serializer.storage.len = len;
+	serializer.lanes_used = 0;
+	return (serializer);
+}
+
+static __inline size_t
+rpc_gss_octets_to_lanes(size_t octets)
+{
+
+	return (octets / BYTES_PER_XDR_UNIT);
+}
+
+static __inline size_t
+rpc_gss_serializer_capacity(const struct rpc_gss_serializer *serializer)
+{
+
+	return (serializer->storage.len / BYTES_PER_XDR_UNIT);
+}
+
+static __inline bool_t
+rpc_gss_serializer_put_u32(struct rpc_gss_serializer *serializer, uint32_t value)
+{
+	u_char *slot;
+
+	if (serializer->lanes_used >= rpc_gss_serializer_capacity(serializer))
+		return (FALSE);
+	slot = serializer->storage.base +
+	    serializer->lanes_used * BYTES_PER_XDR_UNIT;
+	*(int32_t *)(void *)slot = (int32_t)__htonl(value);
+	serializer->lanes_used += 1;
+	return (TRUE);
+}
+
+static __inline struct rpc_gss_octets
+rpc_gss_serializer_reserve(struct rpc_gss_serializer *serializer, size_t octets)
+{
+	struct rpc_gss_octets window;
+	size_t lanes;
+
+	window.base = NULL;
+	window.len = 0;
+	lanes = rpc_gss_octets_to_lanes(octets);
+	if (lanes > rpc_gss_serializer_capacity(serializer) -
+	    serializer->lanes_used)
+		return (window);
+	window.base = serializer->storage.base +
+	    serializer->lanes_used * BYTES_PER_XDR_UNIT;
+	window.len = octets;
+	serializer->lanes_used += lanes;
+	return (window);
+}
+
+static __inline void
+rpc_gss_octets_write(const struct rpc_gss_octets *dst, const void *src)
+{
+	if (dst->base != NULL && dst->len != 0)
+		memcpy(dst->base, src, dst->len);
+}
+
