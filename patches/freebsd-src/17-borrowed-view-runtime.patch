+struct span0 {
+	u_char	*ptr;
+	size_t	 len;
+};
+
+struct slot0 {
+	u_char	*ptr;
+	size_t	 len;
+};
+
+struct lens0 {
+	size_t	 words;
+	size_t	 head;
+};
+
+struct codec0 {
+	struct span0	 arena;
+	struct lens0	 state;
+	const uintptr_t	*rt;
+};
+
+static bool_t
+z0(void *ctx, uint32_t v)
+{
+	struct codec0 *c;
+	u_char *dst;
+
+	c = ctx;
+	if (c->state.head >= c->state.words)
+		return (FALSE);
+	dst = c->arena.ptr + (c->state.head << 2);
+	*(int32_t *)(void *)dst = (int32_t)__htonl(v);
+	c->state.head += 1;
+	return (TRUE);
+}
+
+static struct slot0
+z1(void *ctx, size_t n)
+{
+	struct codec0 *c;
+	struct slot0 out;
+	size_t step;
+
+	c = ctx;
+	out.ptr = NULL;
+	out.len = 0;
+	step = n >> 2;
+	if (step > c->state.words - c->state.head)
+		return (out);
+	out.ptr = c->arena.ptr + (c->state.head << 2);
+	out.len = n;
+	c->state.head += step;
+	return (out);
+}
+
+static void
+z2(void *dst0, const void *src, size_t n)
+{
+	struct slot0 *dst;
+
+	dst = dst0;
+	if (dst->ptr != NULL && dst->len != 0)
+		bcopy(src, dst->ptr, n);
+}
+
+static size_t
+z3(const void *ctx)
+{
+	const struct codec0 *c;
+
+	c = ctx;
+	return (c->state.head << 2);
+}
+
+static const uintptr_t zt[] = {
+	(uintptr_t)&z0,
+	(uintptr_t)&z1,
+	(uintptr_t)&z2,
+	(uintptr_t)&z3
+};
