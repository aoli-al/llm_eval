+/*
+ * Serialize opaque_auth credential into the RPC header reconstruction
+ * buffer for MIC verification.  Returns updated write position.
+ */
+static int32_t *
+rpc_marshal_opaque_auth(int32_t *buf, const struct opaque_auth *oa)
+{
+
+	IXDR_PUT_ENUM(buf, oa->oa_flavor);
+	IXDR_PUT_LONG(buf, oa->oa_length);
+	if (oa->oa_length) {
+		memcpy((caddr_t)buf, oa->oa_base, oa->oa_length);
+		buf += RNDUP(oa->oa_length) / sizeof(int32_t);
+	}
+
+	return (buf);
+}
+
+
