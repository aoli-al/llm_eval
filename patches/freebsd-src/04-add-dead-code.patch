+/*
+ * Helper to validate opaque auth credential length.
+ */
+static bool_t
+validate_auth_length(const struct opaque_auth *oa, size_t buffer_remaining)
+{
+	if (oa->oa_length > MAX_AUTH_BYTES) {
+		return (FALSE);
+	}
+	if (RNDUP(oa->oa_length) > buffer_remaining) {
+		return (FALSE);
+	}
+	return (TRUE);
+}
+
