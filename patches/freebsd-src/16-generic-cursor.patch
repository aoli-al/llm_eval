 	}
+}
+
+static struct part {
+	u_char	*p;
+	u_int	 n;
+};
+
+static struct cursor {
+	u_char	*p;
+	u_int	 cap;
+	u_int	 used;
+};
+
+static struct cursor
+new_cursor(void *base, size_t bytes)
+{
+	struct cursor c;
+
+	c.p = base;
+	c.cap = bytes >> 2;
+	c.used = 0;
+	return (c);
+}
+
+static u_int
+count(const struct opaque_auth *oa)
+{
+
+	return (oa->oa_length);
+}
+
+static bool_t
+put32(struct cursor *c, uint32_t v)
+{
+	u_char *slot;
+
+	if (c->used >= c->cap)
+		return (FALSE);
+	slot = c->p + (c->used << 2);
+	*(int32_t *)(void *)slot = (int32_t)__htonl(v);
+	c->used += 1;
+	return (TRUE);
+}
+
+static struct part
+take(struct cursor *c, u_int n)
+{
+	struct part out;
+	u_int need;
+
+	out.p = NULL;
+	out.n = 0;
+	need = n >> 2;
+	if (need > c->cap - c->used)
+		return (out);
+	out.p = c->p + (c->used << 2);
+	out.n = n;
+	c->used += need;
+	return (out);
+}
+
+static void
+fill(const struct part *out, const void *src)
+{
+	if (out->p != NULL && out->n != 0)
+		memcpy(out->p, src, out->n);
 }
 
