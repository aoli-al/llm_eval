--- sys/rpc/rpcsec_gss/rpcsec_gss_int.h.orig
+++ sys/rpc/rpcsec_gss/rpcsec_gss_int.h
@@ -73,6 +73,69 @@
 /* Maximum sequence number value. */
 #define MAXSEQ		0x80000000
 
+struct rpc_gss_span {
+	u_char	*data;
+	size_t	 len;
+};
+
+struct rpc_gss_mic_writer {
+	struct rpc_gss_span	frame;
+	size_t			written;
+};
+
+static __inline struct rpc_gss_mic_writer
+rpc_gss_mic_writer_new(void *storage, size_t len)
+{
+	struct rpc_gss_mic_writer writer;
+
+	writer.frame.data = storage;
+	writer.frame.len = len;
+	writer.written = 0;
+	return (writer);
+}
+
+static __inline size_t
+rpc_gss_mic_writer_remaining(const struct rpc_gss_mic_writer *writer)
+{
+
+	return (writer->frame.len - writer->written);
+}
+
+static __inline bool_t
+rpc_gss_mic_writer_push_u32(struct rpc_gss_mic_writer *writer, uint32_t value)
+{
+	u_char *slot;
+
+	if (BYTES_PER_XDR_UNIT > rpc_gss_mic_writer_remaining(writer))
+		return (FALSE);
+	slot = writer->frame.data + writer->written * BYTES_PER_XDR_UNIT;
+	*(int32_t *)(void *)slot = (int32_t)__htonl(value);
+	writer->written += 1;
+	return (TRUE);
+}
+
+static __inline struct rpc_gss_span
+rpc_gss_mic_writer_take_bytes(struct rpc_gss_mic_writer *writer, size_t len)
+{
+	struct rpc_gss_span view;
+
+	view.data = NULL;
+	view.len = 0;
+	if (len == 0 || len > rpc_gss_mic_writer_remaining(writer))
+		return (view);
+	view.data = writer->frame.data + writer->written * BYTES_PER_XDR_UNIT;
+	view.len = len;
+	writer->written += RNDUP(len) / BYTES_PER_XDR_UNIT;
+	return (view);
+}
+
+static __inline void
+rpc_gss_span_write(const struct rpc_gss_span *dst, const void *src)
+{
+	if (dst->data != NULL && dst->len != 0)
+		memcpy(dst->data, src, dst->len);
+}
+
